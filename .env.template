# =============================================================================
# MetaTrader 5 Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
#
# The bot reads these variables via os.environ.get() in config.py.
# You can also source them in your shell before running the bot:
#   export $(grep -v '^#' .env | xargs)
# =============================================================================

# ---- MetaTrader 5 Connection ----
# Default host/port for the mt5linux bridge (localhost:18812)
# MT5 must be running with the bridge enabled.
MT5_HOST="localhost"
MT5_PORT="18812"

# MT5 account credentials (only needed if terminal isn't already logged in)
# MT5_LOGIN="12345678"
# MT5_PASSWORD="your_password"
# MT5_SERVER="MetaQuotes-Demo"

# ---- Live / Paper Trading ----
# Set LIVE_TRADING=1 to enable live (real-money) trading.
# Default is "0" = demo/paper trading.
LIVE_TRADING="0"

# Set PAPER_TRADING=1 to simulate trades without real money (default).
PAPER_TRADING="1"

# ---- Daily Loss Kill-Switch ----
# Auto-halt trading if daily P&L drops below this percentage.
# Default: -5% (a 5% loss in one day halts trading).
# DAILY_LOSS_KILL_SWITCH_PCT="-5"

# ---- Telegram Notifications (OPTIONAL) ----
# Create a bot via @BotFather on Telegram to get a token.
# Get your chat ID by messaging @userinfobot.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---- Discord Notifications (OPTIONAL) ----
# Create a webhook in your Discord server channel settings.
DISCORD_WEBHOOK_URL=""

# ---- Email Notifications (OPTIONAL) ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
EMAIL_TO=""